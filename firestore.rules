rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt']) &&
        data.uid == request.auth.uid &&
        data.createdAt is number &&
        (data.get('name', null) == null || (data.name is string && data.name.size() <= 100)) &&
        (data.get('email', null) == null || (data.email is string && data.email.size() <= 100)) &&
        (data.get('location', null) == null || (data.location is string && data.location.size() <= 100)) &&
        (data.get('phone', null) == null || (data.phone is string && data.phone.size() <= 20)) &&
        (data.get('age', null) == null || data.age is number) &&
        (data.get('updatedAt', null) == null || data.updatedAt is number);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) && incoming().uid == existing().uid && incoming().createdAt == existing().createdAt && incoming().diff(existing()).affectedKeys().hasAny(['name', 'email', 'location', 'phone', 'age', 'updatedAt']);
    }

    function isValidDoctor(data) {
      return data.keys().hasAll(['name', 'hospital', 'fees']) &&
        data.name is string && data.name.size() <= 100 &&
        data.hospital is string && data.hospital.size() <= 100 &&
        data.fees is number &&
        (data.qualifications == null || (data.qualifications is string && data.qualifications.size() <= 200)) &&
        (data.rating == null || data.rating is number) &&
        (data.reviews == null || data.reviews is number) &&
        (data.wait == null || (data.wait is string && data.wait.size() <= 50)) &&
        (data.slots == null || (data.slots is string && data.slots.size() <= 50)) &&
        (data.availableMsg == null || (data.availableMsg is string && data.availableMsg.size() <= 50)) &&
        (data.isAvailable == null || data.isAvailable is bool) &&
        (data.avatarBg == null || (data.avatarBg is string && data.avatarBg.size() <= 50)) &&
        (data.avatarEmoji == null || (data.avatarEmoji is string && data.avatarEmoji.size() <= 10)) &&
        (data.categories == null || (data.categories is list && data.categories.size() <= 10 && (data.categories.size() == 0 || data.categories[0] is string)));
    }

    function isValidReview(data) {
        return data.keys().hasAll(['userId', 'userName', 'rating', 'createdAt']) &&
        data.userId == request.auth.uid &&
        data.userName is string && data.userName.size() <= 100 &&
        data.rating is number && data.rating >= 1 && data.rating <= 5 &&
        (data.get('comment', null) == null || (data.comment is string && data.comment.size() <= 2000)) &&
        data.createdAt == request.time;
    }

    function isValidReviewUpdate(data, oldData) {
        return data.diff(oldData).affectedKeys().hasOnly(['rating', 'comment', 'updatedAt']) &&
        (data.get('rating', oldData.rating) is number && data.get('rating', oldData.rating) >= 1 && data.get('rating', oldData.rating) <= 5) &&
        (data.get('comment', null) == null || (data.comment is string && data.comment.size() <= 2000));
    }

    match /doctors/{doctorId} {
      allow read: if true;
      allow create, update: if true; 

      match /bookedSlots/{slotId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && reviewId == request.auth.uid && isValidReview(incoming());
        allow update: if isSignedIn() && reviewId == request.auth.uid && isValidReviewUpdate(incoming(), existing());
        allow delete: if isSignedIn() && reviewId == request.auth.uid;
      }
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'doctorId', 'status', 'createdAt', 'updatedAt']) &&
        data.userId == request.auth.uid &&
        data.doctorId is string && data.doctorId.size() <= 128 &&
        data.status is string && data.status in ['upcoming', 'completed', 'cancelled'] &&
        data.createdAt is number &&
        data.updatedAt is number &&
        (data.get('patientName', null) == null || (data.patientName is string && data.patientName.size() <= 100)) &&
        (data.get('patientAge', null) == null || data.patientAge is number) &&
        (data.get('symptoms', null) == null || (data.symptoms is string && data.symptoms.size() <= 500)) &&
        (data.get('token', null) == null || (data.token is string && data.token.size() <= 20)) &&
        (data.get('date', null) == null || (data.date is string && data.date.size() <= 100)) &&
        (data.get('timeSlot', null) == null || (data.timeSlot is string && data.timeSlot.size() <= 100)) &&
        (data.get('id', null) == null || (data.id is string && data.id.size() <= 128));
    }

    match /bookings/{bookingId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming()) && exists(/databases/$(database)/documents/doctors/$(incoming().doctorId));
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidBooking(incoming()) && incoming().userId == existing().userId && incoming().doctorId == existing().doctorId && incoming().createdAt == existing().createdAt && incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt']);
    }
  }
}
