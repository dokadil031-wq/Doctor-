{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["uid", "createdAt"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile info",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "qualifications": { "type": "string" },
        "hospital": { "type": "string" },
        "fees": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "wait": { "type": "string" },
        "slots": { "type": "string" },
        "availableMsg": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "avatarBg": { "type": "string" },
        "avatarEmoji": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "hospital", "fees"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Token / Appointment for a user with a doctor",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientAge": { "type": "number" },
        "symptoms": { "type": "string" },
        "tokenNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "completed", "cancelled"] },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["userId", "doctorId", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/entities/Doctor" },
      "description": "Stores all doctors (global read)"
    },
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "Stores all bookings/appointments"
    }
  }
}
